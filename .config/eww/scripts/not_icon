#!/bin/bash

# Fetch the current DND status
DND_STATUS=$(swaync-client --get-dnd)

# Fetch the number of unread notifications
UNREAD_COUNT=$(swaync-client --count)

# Determine the icon to display
if [ "$DND_STATUS" = "true" ]; then
    echo "箚궀"  # DND enabled icon
elif [ "$UNREAD_COUNT" -gt 0 ]; then
    echo "茶뀵"  # Unread notifications icon
else
    echo "箚굾"  # No notifications icon
fi
