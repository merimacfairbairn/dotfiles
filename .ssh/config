AddKeysToAgent yes

# Default GitHub account (personal)
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

# Secret GitHub account
Host github.com-secret
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_secret
    IdentitiesOnly yes
